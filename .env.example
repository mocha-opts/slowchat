NODE_ENV=development
LOG_LEVEL=info
SHUTDOWN_GRACE_MS=15000

API_PORT=3000
REALTIME_PORT=3001
EVENT_WORKER_PORT=3002
JOB_WORKER_PORT=3003

DATABASE_URL=postgresql://im_app:im_dev_password@localhost:5432/im

REDIS_REALTIME_URL=redis://im_realtime:realtime_dev_password@localhost:6379/0
REDIS_REALTIME_PREFIX=im:realtime:
REDIS_JOBS_URL=redis://im_jobs:jobs_dev_password@localhost:6380/0
REDIS_JOBS_PREFIX=im:jobs:

RABBITMQ_URL=amqp://im_app:rabbit_dev_password@localhost:5672/%2Fim

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=im_minio
S3_SECRET_KEY=minio_dev_password
S3_BUCKET=im-dev
S3_FORCE_PATH_STYLE=true
S3_AUTO_CREATE_BUCKET=true
