NODE_ENV=development
LOG_LEVEL=info
SHUTDOWN_GRACE_MS=15000

API_PORT=3000
REALTIME_PORT=3001
EVENT_WORKER_PORT=3002
JOB_WORKER_PORT=3003

DATABASE_URL=postgresql://im_app:im_dev_password@localhost:5432/im

REDIS_REALTIME_URL=redis://im_realtime:realtime_dev_password@localhost:6379/0
REDIS_REALTIME_PREFIX=im:realtime:
REDIS_JOBS_URL=redis://im_jobs:jobs_dev_password@localhost:6380/0
REDIS_JOBS_PREFIX=im:jobs:

RABBITMQ_URL=amqp://im_app:rabbit_dev_password@localhost:5672/%2Fim
OUTBOX_POLL_INTERVAL_MS=250
OUTBOX_BATCH_SIZE=100
OUTBOX_LOCK_MS=30000
OUTBOX_MAX_ATTEMPTS=20
OUTBOX_RETRY_BASE_MS=500
OUTBOX_RETRY_MAX_MS=60000
RABBITMQ_PREFETCH=50
RABBITMQ_RETRY_DELAYS_MS=5000,30000,300000
RABBITMQ_CONSUMER_LEASE_MS=30000

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=im_minio
S3_SECRET_KEY=minio_dev_password
S3_BUCKET=im-dev
S3_FORCE_PATH_STYLE=true
S3_AUTO_CREATE_BUCKET=true

JWT_ISSUER=slowchat
JWT_AUDIENCE=slowchat-clients
JWT_KEY_ID=dev-rs256-1
JWT_PRIVATE_KEY_PATH=.local/auth/private.pem
JWT_PUBLIC_KEY_PATH=.local/auth/public.pem
AUTH_REFRESH_TOKEN_PEPPER=dev_refresh_pepper_change_in_production_32_chars
AUTH_CHALLENGE_PEPPER=dev_challenge_pepper_change_in_production_32_chars
AUTH_IDENTIFIER_PEPPER=dev_identifier_pepper_change_in_production_32_chars
AUTH_MAX_DEVICES=5
AUTH_CHALLENGE_TTL_SECONDS=600
AUTH_CHALLENGE_MAX_ATTEMPTS=5
AUTH_CHALLENGE_RESEND_SECONDS=60
AUTH_LOGIN_IDENTITY_LIMIT=5
AUTH_LOGIN_IP_LIMIT=20
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_EXPOSE_CHALLENGE_CODE=true
AUTH_ALLOWED_WS_ORIGINS=http://localhost:3000,http://localhost:5173
