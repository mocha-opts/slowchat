{
  "name": "@im/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./websocket": {
      "types": "./dist/websocket/index.d.ts",
      "default": "./dist/websocket/index.js"
    },
    "./messages": {
      "types": "./dist/messages/index.d.ts",
      "default": "./dist/messages/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    },
    "./sync": {
      "types": "./dist/api/sync.d.ts",
      "default": "./dist/api/sync.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test:integration": "node -e \"process.exit(0)\"",
    "test:contract": "node -e \"process.exit(0)\"",
    "test:e2e": "node -e \"process.exit(0)\"",
    "test:unit": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@im/typescript-config": "workspace:*",
    "typescript": "6.0.3"
  }
}
