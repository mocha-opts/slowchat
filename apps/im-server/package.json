{
  "name": "@im/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/entrypoints/api.main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migration:generate": "node --import tsx ./node_modules/typeorm/cli.js migration:generate src/platform/database/migrations/generated -d src/compositions/database-data-source.ts",
    "db:migration:revert": "node --import tsx ./node_modules/typeorm/cli.js migration:revert -d src/compositions/database-data-source.ts",
    "db:migration:run": "node --import tsx ./node_modules/typeorm/cli.js migration:run -d src/compositions/database-data-source.ts",
    "db:migration:show": "node --import tsx ./node_modules/typeorm/cli.js migration:show -d src/compositions/database-data-source.ts",
    "dev:api": "tsx watch src/entrypoints/api.main.ts",
    "dev:event-worker": "tsx watch src/entrypoints/event-worker.main.ts",
    "dev:job-worker": "tsx watch src/entrypoints/job-worker.main.ts",
    "dev:realtime": "tsx watch src/entrypoints/realtime.main.ts",
    "lint": "eslint src test *.ts",
    "start:api": "node dist/entrypoints/api.main.js",
    "start:event-worker": "node dist/entrypoints/event-worker.main.js",
    "start:job-worker": "node dist/entrypoints/job-worker.main.js",
    "start:realtime": "node dist/entrypoints/realtime.main.js",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@aws-sdk/s3-request-presigner": "3.1090.0",
    "@im/contracts": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/platform-socket.io": "11.1.28",
    "@nestjs/typeorm": "11.0.3",
    "@nestjs/websockets": "11.1.28",
    "@node-rs/argon2": "2.0.2",
    "@socket.io/redis-adapter": "8.3.0",
    "@socket.io/redis-emitter": "5.1.0",
    "amqplib": "2.0.1",
    "bullmq": "5.80.9",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "nestjs-pino": "4.6.1",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "typeorm": "1.1.0",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@im/test-utils": "workspace:*",
    "@im/typescript-config": "workspace:*",
    "@nestjs/testing": "11.1.28",
    "@swc/core": "1.15.46",
    "@types/amqplib": "0.10.8",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/supertest": "7.2.1",
    "@vitest/coverage-v8": "4.1.10",
    "socket.io-client": "4.8.3",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "unplugin-swc": "1.5.9",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
